{
  "name": "@spectra-js/tracker",
  "version": "1.0.1",
  "description": "Analytics tracking script for Spectra",
  "keywords": [
    "spectra",
    "spectra-js",
    "tracker",
    "tracking"
  ],
  "homepage": "https://github.com/mvallejo3/spectra/tree/main/script",
  "bugs": {
    "url": "https://github.com/mvallejo3/spectra/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvallejo3/spectra.git#main"
  },
  "license": "MIT",
  "author": "mvallejo3",
  "type": "commonjs",
  "main": "dist/tracker.js",
  "types": "./dist/tracker.d.ts",
  "scripts": {
    "build": "npm run prebuild && tsc && node build.js",
    "watch": "tsc --watch",
    "prepcdn": "cp dist/spectra.js ../cdn/public/spectra.js",
    "deploycdn": "yarn prepcdn && cd ../cdn && yarn deploy",
    "prebuild": "node -e \"require('fs').writeFileSync('src/version.ts', 'export const version = \\\"' + require('./package.json').version + '\\\";\\n')\""
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  }
}
