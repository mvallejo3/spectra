{
  "name": "@spectra-js/tracker",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Analytics tracking script for Spectra",
  "main": "dist/tracker.js",
  "keywords": [
    "spectra",
    "spectra-js",
    "tracker",
    "tracking"
  ],
  "scripts": {
    "build": "npm run prebuild && tsc && node build.js",
    "watch": "tsc --watch",
    "prepcdn": "cp dist/spectra.js ../cdn/public/spectra.js",
    "deploycdn": "yarn prepcdn && cd ../cdn && yarn deploy",
    "prebuild": "node -e \"require('fs').writeFileSync('src/version.ts', 'export const version = \\\"' + require('./package.json').version + '\\\";\\n')\""
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  }
}
